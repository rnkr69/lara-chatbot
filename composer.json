{
    "name": "rnkr69/lara-chatbot",
    "description": "Embeddable chatbot for Laravel 11/12 with LLM streaming, backend tools, frontend tools and a stack-agnostic Web Component widget.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "chatbot",
        "llm",
        "prism",
        "streaming",
        "tools",
        "web-component"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "prism-php/prism": "^0.100"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rnkr69\\LaraChatbot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rnkr69\\LaraChatbot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rnkr69\\LaraChatbot\\ChatbotServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage",
        "test:coverage-min": "pest --coverage --min=75"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
