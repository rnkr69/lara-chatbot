<?php

declare(strict_types=1);

namespace {{ namespace }};

use Backpack\CRUD\app\Http\Controllers\CrudController;
use Backpack\CRUD\app\Library\CrudPanel\CrudPanelFacade as CRUD;
use Rnkr69\LaraChatbot\Models\Conversation;

/**
 * Read-only Backpack CRUD for `chatbot_conversations`. Published by
 * `chatbot:install --backpack-admin` (rnkr69/lara-chatbot v1.1.1, finding #14.f).
 *
 * To enable the route in your Backpack admin, add to `routes/backpack/custom.php`:
 *
 *     Route::crud('chatbot-conversation', '\\App\\Http\\Controllers\\Admin\\ChatbotConversationCrudController');
 *
 * Only exposes List + Show (it does not allow create / edit / delete from the
 * admin; the package manages persistence from the chat endpoint). If you want
 * to allow bulk deletion from the admin, add `CRUD::operation(...)` and the
 * corresponding handler.
 */
class {{ class }} extends CrudController
{
    use \Backpack\CRUD\app\Http\Controllers\Operations\ListOperation;
    use \Backpack\CRUD\app\Http\Controllers\Operations\ShowOperation;

    public function setup(): void
    {
        CRUD::setModel(Conversation::class);
        CRUD::setRoute(config('backpack.base.route_prefix') . '/chatbot-conversation');
        CRUD::setEntityNameStrings('chatbot conversation', 'chatbot conversations');
    }

    protected function setupListOperation(): void
    {
        CRUD::column('id');
        CRUD::column('user_id')->label('User');
        CRUD::column('title');
        CRUD::column('created_at');
        CRUD::column('updated_at');

        CRUD::addFilter([
            'name'  => 'user_id',
            'type'  => 'text',
            'label' => 'User ID',
        ], false, function ($value) {
            CRUD::addClause('where', 'user_id', $value);
        });
    }

    protected function setupShowOperation(): void
    {
        $this->setupListOperation();

        CRUD::column('metadata')->type('array');
        CRUD::column('deleted_at');
    }
}
