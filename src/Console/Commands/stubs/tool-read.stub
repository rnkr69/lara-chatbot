 * returns `ToolResult::error('validation', ...)` without invoking you.
 */
class {{ class }} extends BaseBackendTool
{
    public function name(): string
    {
        return '{{ tool_name }}';
    }

    public function description(): string
    {
        // TODO: a single LLM-oriented sentence. Example:
