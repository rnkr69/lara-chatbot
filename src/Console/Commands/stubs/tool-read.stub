        return [
            'type'       => 'object',
            'properties' => [],
            'required'   => [],
        ];
    }

    public function permissions(): array
    {
        // AND permissions. Empty list = public tool.
        return [];
    }

    public function defaultScope(): AccessScope
    {
        // Effective scope: Self/Team/All. The package uses this value to
        // filter the query with `accessibleQuery()`.
        return AccessScope::Self;
    }

