    public function confirmation(): ConfirmationLevel
    {
        // Backend tools en v1 sólo soportan Auto. `Confirm`/`Manual` quedan
        // en backlog v2 (ver §7 PROGRESS.md). Para acciones críticas usa
        // una FrontendTool de confirmación (E11/E16) que dispare esta.
        return ConfirmationLevel::Auto;
    }

